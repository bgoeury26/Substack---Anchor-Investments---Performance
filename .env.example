# ── Portfolio identity ──────────────────────────────────────────────────────
PORTFOLIO_NAME=My Model Portfolio
PORTFOLIO_DESCRIPTION=A fictive model portfolio published alongside my Substack.
SUBSTACK_URL=https://yoursubstack.substack.com
BASE_CAPITAL=100000

# ── Admin auth ───────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin

# Generate a bcrypt hash:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
# Then paste the result below:
ADMIN_PASSWORD_HASH=$2b$12$EXAMPLE_HASH_REPLACE_ME

# ── Storage ───────────────────────────────────────────────────────────────────
DB_PATH=data/portfolio.db

# ── Market data ───────────────────────────────────────────────────────────────
# "yfinance" (default, no key needed) or "openbb"
DATA_PROVIDER=yfinance
PRICE_CACHE_TTL=900
HISTORY_CACHE_TTL=3600
